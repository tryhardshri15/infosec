def vigenere_encrypt(text, key):
    result = ""
    key = key.lower()
    for i, char in enumerate(text):
        if char.isalpha():
            shift = ord(key[i % len(key)]) - 97
            result += chr((ord(char.lower()) - 97 + shift) % 26 + 97)
        else:
            result += char
    return result

def vigenere_decrypt(text, key):
    result = ""
    key = key.lower()
    for i, char in enumerate(text):
        if char.isalpha():
            shift = ord(key[i % len(key)]) - 97
            result += chr((ord(char) - 97 - shift) % 26 + 97)
        else:
            result += char
    return result
