MONOALPHABETIC CIPHER: 

import string
import random

letters = list(string.ascii_lowercase)
shuffled = letters.copy()
random.shuffle(shuffled)

key_map = dict(zip(letters, shuffled))
reverse_map = {v: k for k, v in key_map.items()}

def encrypt(text):
    return ''.join(key_map.get(c, c) for c in text.lower())

def decrypt(text):
    return ''.join(reverse_map.get(c, c) for c in text.lower())

msg = "hello"
enc = encrypt(msg)
print("Encrypted:", enc)
print("Decrypted:", decrypt(enc))



